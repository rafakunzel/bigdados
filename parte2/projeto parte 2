import polars as pl
pl.Config.set_fmt_float("full")
import time
import matplotlib.pyplot as plt
import seaborn as sns

# Definindo a consulta estatística
inicial=pl.scan_parquet("fidiario_POLARS.parquet")
analisevltotal = inicial.select([
        pl.col("vltotal").min().alias("minimo"),
        pl.col("vltotal").mean().alias("media"),
        pl.col("vltotal").std().alias ("desvio_padrao"),
        pl.col("vltotal").max().alias("maximo"),
        pl.col("vltotal").median().alias("mediana"),
        pl.col('vltotal').quantile(0.25).alias('Q1'),
        pl.col('vltotal').quantile(0.75).alias('Q3'),
        pl.col('vltotal').skew().alias('Assimetria'),
        pl.col('vltotal').kurtosis().alias('Curtose'),
    ]).collect()
display(analisevltotal)
#analise gráfico boxsplot
q1=analisevltotal['Q1'][0]
q3=analisevltotal['Q3'][0]
iqr=q3-q1
limiteinf=q1-(1.5*iqr)
limitesup=q3+(1.5*iqr)
outiliers=inicial.filter((pl.col('vltotal')<limiteinf) | (pl.col('vltotal')>limitesup)).select(['tipfundoclasse','vltotal']).collect()
# automatização assimetria
assimetria=analisevltotal['Assimetria'][0]
if -0.5 <= assimetria <= 0.5:
  print('Distribuição Simétrica — dados bem balanceados')
elif assimetria > 0.5:
  print('Assimétrica Positiva — existem valores muito altos puxando a média')

